{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yakovkazinets/VibeSec/schemas/release-manifest-v1.json",
  "title": "VibeSec release manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version", "source", "artifacts", "schema_versions", "tool_versions", "creation_mode", "provenance", "checksum_file", "signature_bundle"],
  "properties": {
    "schema_version": {"const": 1},
    "version": {"type": "string", "maxLength": 64},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit"],
      "properties": {
        "repository": {"const": "https://github.com/yakovkazinets/VibeSec"},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "sha256", "size", "media_type"],
        "properties": {
          "name": {"enum": ["vibesec-consumer-bundle.zip", "sbom.cyclonedx.json", "sbom.spdx.json"]},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size": {"type": "integer", "minimum": 0, "maximum": 52428800},
          "media_type": {"type": "string", "maxLength": 64}
        }
      }
    },
    "schema_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_manifest", "provenance", "cyclonedx", "spdx"],
      "properties": {
        "release_manifest": {"const": 1},
        "provenance": {"const": 1},
        "cyclonedx": {"const": "1.7"},
        "spdx": {"const": "SPDX-2.3"}
      }
    },
    "tool_versions": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 16,
      "propertyNames": {"pattern": "^[a-z0-9][a-z0-9-]{0,31}$"},
      "additionalProperties": {"type": "string", "minLength": 1, "maxLength": 64}
    },
    "creation_mode": {"enum": ["local-preparation", "trusted-github-workflow"]},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "predicate_type"],
      "properties": {
        "name": {"const": "provenance.intoto.jsonl"},
        "predicate_type": {"const": "https://slsa.dev/provenance/v1"}
      }
    },
    "checksum_file": {"const": "SHA256SUMS"},
    "signature_bundle": {"const": "SHA256SUMS.sigstore.json"}
  }
}
